{
  "manifest_version": 3,
  "name": "Surpasse-Toi Tracker",
  "version": "0.1.0",
  "description": "Mesure le temps passé par domaine et l'envoie vers le dashboard Surpasse-Toi.",
  "permissions": ["storage", "idle", "alarms", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Surpasse-Toi Tracker"
  }
}
